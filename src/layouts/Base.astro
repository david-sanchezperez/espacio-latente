---
import '../styles/global.css';
import { t, type Idioma } from '../i18n/ui';

interface Props {
  titulo?: string;
  descripcion?: string;
  lang?: Idioma;
  /** URL de la versión equivalente en el otro idioma, para el selector y los hreflang. */
  altHref?: string;
}

const { titulo = 'Espacio Latente', descripcion, lang = 'es', altHref } = Astro.props;
const strings = t(lang);
const desc = descripcion ?? strings['meta.descripcion'];
const otroIdioma: Idioma = lang === 'es' ? 'en' : 'es';
const enlaceIdioma = altHref ?? (lang === 'es' ? '/en/' : '/');
const enlaceBuzon = lang === 'es' ? '/#buzon' : '/en/#buzon';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    <meta name="description" content={desc} />
    <link rel="alternate" hreflang="es" href={lang === 'es' ? Astro.url.pathname : enlaceIdioma} />
    <link rel="alternate" hreflang="en" href={lang === 'en' ? Astro.url.pathname : enlaceIdioma} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:image" content="https://espacio-latente.com/images/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content="https://espacio-latente.com/images/og.png" />
  </head>
  <body>
    <nav class="chasis">
      <div class="contenedor chasis-fila">
        <a class="chasis-marca" href={lang === 'es' ? '/' : '/en/'}>
          <span class="chasis-punto"></span> espacio-latente.com
        </a>
        <div class="chasis-derecha">
          <a class="chasis-radar" href="https://radar.espacio-latente.com/">{strings['nav.radar']}</a>
          <a class="chasis-idioma" href={enlaceIdioma} hreflang={otroIdioma}>{strings['idioma.cambiar']}</a>
        </div>
      </div>
    </nav>
    <main class="contenedor">
      <slot />
    </main>
    <footer>
      <div class="contenedor">
        {strings['footer.texto']} · <a href={enlaceBuzon}>{strings['footer.buzon']}</a> · <a href="https://www.linkedin.com/in/davidsanchezperez/" target="_blank" rel="noopener">{strings['footer.linkedin']}</a>
      </div>
    </footer>
  </body>
</html>
